# Normalize line endings for cross-platform (Windows dev → Vercel/Linux deploy)
* text=auto eol=lf

# Explicit text types
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.ps1 text eol=crlf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
